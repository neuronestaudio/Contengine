# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret required by /api/cron/publish (set the same value in Vercel env)
CRON_SECRET=generate-a-long-random-string

# API key for the tool layer + ingest endpoint (used later by MCP / automations)
TOOLS_API_KEY=generate-another-long-random-string

# Meta Graph API version (page tokens are stored per client in the DB)
META_GRAPH_VERSION=v21.0

# Optional: local Chrome path for `npm run dev` rendering (Windows example)
# LOCAL_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
